{
  "name": "playwright-e2e-typescript",
  "version": "2.0.0",
  "description": "Modern Playwright TypeScript E2E framework — Page Object Model, fixtures, API, visual, ARIA & accessibility testing.",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test --ui",
    "test:headed": "playwright test --headed",
    "test:debug": "playwright test --debug",
    "test:e2e": "playwright test --grep @e2e",
    "test:api": "playwright test --grep @api",
    "test:a11y": "playwright test --grep @a11y",
    "test:visual": "playwright test --grep @visual",
    "test:smoke": "playwright test --grep @smoke",
    "test:chromium": "playwright test --project=chromium",
    "test:failed": "playwright test --last-failed",
    "test:changed": "playwright test --only-changed",
    "test:trace": "playwright test --trace on",
    "report": "playwright show-report",
    "codegen": "playwright codegen https://www.saucedemo.com",
    "install:browsers": "playwright install --with-deps",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "mcp": "npx @playwright/mcp@latest"
  },
  "keywords": [
    "playwright",
    "typescript",
    "e2e",
    "testing",
    "page-object-model",
    "accessibility",
    "mcp"
  ],
  "author": "dima.g",
  "license": "MIT",
  "devDependencies": {
    "@axe-core/playwright": "^4.10.2",
    "@eslint/js": "^9.39.0",
    "@faker-js/faker": "^10.5.0",
    "@playwright/mcp": "^0.0.76",
    "@playwright/test": "^1.61.0",
    "@types/node": "^24.10.0",
    "dotenv": "^17.2.3",
    "eslint": "^9.39.0",
    "eslint-plugin-playwright": "^2.2.2",
    "prettier": "^3.7.0",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.49.0"
  }
}
